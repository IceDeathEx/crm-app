// Prisma schema for SGMakanHealthy
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

model User {
  id              String         @id @default(uuid())
  phone           String         @unique
  phoneVerifiedAt DateTime?
  username        String         @unique
  role            Role           @default(USER)
  age             Int?
  gender          Gender?
  activityLevel   ActivityLevel?
  heightCm        Float?
  weightKg        Float?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  sessions Session[]
  reviews  Review[]
}

model Otp {
  id         String    @id @default(uuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([phone])
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Dish {
  id               String   @id @default(uuid())
  slug             String   @unique
  name             String
  shortDescription String   @db.Text
  category         String?
  imageUrl         String?
  caloriesKcal     Int
  proteinG         Float
  carbsG           Float
  fatG             Float
  sodiumMg         Int
  fiberG           Float
  sugarG           Float
  servingNote      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  stallDishes StallDish[]
}

model Stall {
  id        String   @id @default(uuid())
  name      String
  address   String
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stallDishes StallDish[]
}

model StallDish {
  id         String   @id @default(uuid())
  stallId    String
  dishId     String
  priceCents Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  stall   Stall    @relation(fields: [stallId], references: [id], onDelete: Cascade)
  dish    Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@unique([stallId, dishId])
  @@index([dishId])
  @@index([stallId])
}

model Review {
  id          String   @id @default(uuid())
  stallDishId String
  userId      String
  isAnonymous Boolean  @default(false)
  description String   @db.Text
  tasteRating Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stallDish StallDish @relation(fields: [stallDishId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stallDishId])
  @@index([userId])
}
